<!-- Quick Settings tile icon: same artwork as the app launcher icon
     (ic_launcher_foreground), scaled up to fill the tile since the
     adaptive-icon version reserves a large safe-zone margin. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:pivotX="55"
        android:pivotY="51"
        android:scaleX="1.6"
        android:scaleY="1.6">

        <!-- Spotlight beam: solid stroke + translucent inner fill -->
        <path
            android:pathData="M38,72 L57,31 A45,45 0 0 1 79,53 Z"
            android:fillColor="#20FFFFFF"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="4.5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"/>

        <!-- Persistent notification: source dot + radiating waves -->
        <path
            android:pathData="M32,32 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0"
            android:fillColor="#FFFFFFFF"/>
        <path
            android:pathData="M38,32 A6,6 0 0 1 32,38"
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.5"
            android:strokeLineCap="round"/>
        <path
            android:pathData="M43,32 A11,11 0 0 1 32,43"
            android:fillColor="#00000000"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.5"
            android:strokeLineCap="round"/>
    </group>
</vector>
